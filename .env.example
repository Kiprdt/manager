# ── Локальная разработка (без Docker) ───────────────────────────────────────
# SQLite-файл рядом со схемой Prisma.
DATABASE_URL="file:./dev.db"
PORT=3001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# ── Сервер (docker compose) ─────────────────────────────────────────────────
# Эти переменные подставляются в docker-compose.yml. На сервере скопируйте
# этот файл в .env и заполните. БД — SQLite на docker-томе (DATABASE_URL задан
# в самом compose), Postgres не используется.
#
# Секрет JWT — ОБЯЗАТЕЛЕН в проде, ≥16 символов. Сгенерировать: openssl rand -hex 32
JWT_SECRET=
# Порт веб-интерфейса (443 и 8443 заняты VPN).
WEB_PORT=8080
# CORS: доступ по IP — оставьте *, либо укажите http://<IP>:8080
CORS_ORIGIN=*

# ── Telegram-синхронизация (опционально) ────────────────────────────────────
# Токен бота и chat id задаются в Настройках приложения (или здесь как дефолт).
# Режим получения апдейтов: off (по умолчанию) | polling | webhook
# TELEGRAM_MODE=polling
# TELEGRAM_BOT_TOKEN=123456:ABC...

# ── LLM для анализа/прогноза (опционально, OpenAI-совместимый API) ───────────
# LLM_API_KEY=sk-...
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini

# ── Прокси для исходящих запросов (если блокировки в РФ к Telegram/Google) ───
# NODE_USE_ENV_PROXY=1
# HTTPS_PROXY=http://127.0.0.1:1080
# HTTP_PROXY=http://127.0.0.1:1080
