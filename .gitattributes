# Нормализация переводов строк. Файлы, исполняемые в Linux-контейнерах,
# обязаны быть с LF, иначе ломаются в Docker.
* text=auto eol=lf

*.sh        text eol=lf
Dockerfile  text eol=lf
*.Dockerfile text eol=lf
nginx.conf  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Бинарные/невыравниваемые
*.png binary
*.jpg binary
*.ico binary
*.db  binary
